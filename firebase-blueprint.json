{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role management",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "coach"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student Details",
      "description": "Basketball student details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "aadhaar": { "type": "string" },
        "joinedDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "photoUrl": { "type": "string" },
        "jerseyNumber": { "type": "string" },
        "batch": { "type": "string", "enum": ["Morning Batch 1", "Morning Batch 2", "Evening Batch 1", "Evening Batch 2", "Weekend"] }
      },
      "required": ["name", "dob", "age", "gender", "contact", "address", "aadhaar", "joinedDate", "status", "batch"]
    },
    "TeamReport": {
      "title": "Team Report",
      "description": "Team sheet with 5-12 players",
      "type": "object",
      "properties": {
        "academyName": { "type": "string" },
        "academyAddress": { "type": "string" },
        "academyContact": { "type": "string" },
        "coachName": { "type": "string" },
        "presidentName": { "type": "string" },
        "secretaryName": { "type": "string" },
        "players": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "studentId": { "type": "string" },
              "name": { "type": "string" },
              "jerseyNumber": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["academyName", "academyAddress", "academyContact", "coachName", "presidentName", "secretaryName", "players", "createdAt"]
    },
    "Fee": {
      "title": "Fee Collection",
      "description": "Fee payment records",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "month": { "type": "string" },
        "year": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Pending"] }
      },
      "required": ["studentId", "amount", "date", "month", "year", "status"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Daily attendance tracking",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Present", "Absent"] }
      },
      "required": ["studentId", "date", "status"]
    },
    "Activity": {
      "title": "Recent Activity",
      "description": "Feed of academy activities",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "date"]
    },
    "Schedule": {
      "title": "Upcoming Schedule",
      "description": "Weekly academy schedule",
      "type": "object",
      "properties": {
        "day": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string" }
      },
      "required": ["day", "title", "time"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/students/{studentId}": { "schema": "Student", "description": "Student records" },
    "/fees/{feeId}": { "schema": "Fee", "description": "Fee records" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance logs" },
    "/team-reports/{reportId}": { "schema": "TeamReport", "description": "Generated team sheets" },
    "/activities/{activityId}": { "schema": "Activity", "description": "Academy activities" },
    "/schedules/{scheduleId}": { "schema": "Schedule", "description": "Weekly schedules" }
  }
}
